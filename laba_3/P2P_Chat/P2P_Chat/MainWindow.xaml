<Window x:Class="P2P_Chat.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:P2P_Chat"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ListBox Grid.Row="0" ItemsSource="{Binding Events}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}" Margin="0,0,5,0"/>
                        <TextBlock Text=" - " Margin="0,0,5,0"/>
                        <TextBlock Text="{Binding EventText}" TextWrapping="Wrap"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <DockPanel Grid.Row="1" Margin="0,10,0,0">
            <TextBox DockPanel.Dock="Left" Width="600"
                     Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}" />
            <Button Content="Отправить" Margin="10,0,0,0"
                    Command="{Binding SendCommand}" />
        </DockPanel>
    </Grid>
</Window>
