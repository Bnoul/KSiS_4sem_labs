<Window x:Class="laba_3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:laba_3"
        mc:Ignorable="d"
        Title="MainWindow" Height="200" Width="450">
    <Grid>
        <StackPanel Margin="10,10,10,10">
            <TextBlock Text="Выберите окно:" 
                   FontSize="16" 
                   HorizontalAlignment="Center"
                   Margin="0,0,0,10"/>

            <Button Content="Окно сервера"
                Click="OpenServer_Click"
                Margin="0,0,0,5"
                Height="30"/>

            <Button Content="Окно клиента"
                Click="OpenClient_Click"
                Height="30"/>
        </StackPanel>
    </Grid>
</Window>
